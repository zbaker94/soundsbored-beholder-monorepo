# UDP profile config (VPS + Caddy auto-TLS). Copy to deploy/udp/.env and fill in.

# Two public hostnames. Point an A record for EACH at this host's IP.
#   BEHOLDER_HOST - the listener web app
#   RELAY_HOST    - the relay: token endpoint (/token) AND LiveKit SFU (wss)
BEHOLDER_HOST=beholder.example.com
RELAY_HOST=relay.example.com

# The room name. Baked into Beholder + shown read-only ("set by host") so
# listeners only enter the password. Must match what the SoundsBored app
# publishes to. Leave empty to let listeners pick the room themselves.
ROOM=world1

# The shared room password you distribute to players (relay exits 1 if unset).
ROOM_PASSWORD=

# LiveKit SFU credentials — CHANGE THESE from the dev defaults for any real
# deployment. The relay signs tokens with them; the SFU verifies with them, so
# both must match. The SECRET must be at least 32 characters (LiveKit rejects
# shorter ones) — e.g. `openssl rand -hex 24`.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-to-a-long-random-secret-32-chars-min
