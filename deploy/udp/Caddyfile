# Caddy reverse proxy for the UDP profile. Automatic Let's Encrypt TLS for both
# names — no account, just A records pointing at this host and ports 80/443 open.
#
# DNS: point BEHOLDER_HOST and RELAY_HOST at this host's IP.
#
# Media (7881/tcp, 7882/udp) does NOT go through Caddy — it is published directly
# from the livekit container to the host (see docker-compose.yml).

# Beholder listener.
{$BEHOLDER_HOST} {
	reverse_proxy beholder:80
}

# The relay: token endpoint + LiveKit SFU signaling behind one host.
{$RELAY_HOST} {
	# Token endpoint (POST /token) + health check → the token service.
	@token path /token /token/* /healthz
	handle @token {
		reverse_proxy token:8080
	}
	# Everything else → LiveKit signaling (wss). The client connects to
	# wss://{$RELAY_HOST}/rtc; no path collision since Beholder is on its own host.
	# SFU_URL = wss://{$RELAY_HOST}.
	handle {
		reverse_proxy livekit:7880
	}
}
