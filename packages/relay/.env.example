# Relay environment (Shared Contract C8). Copy to `.env` and set ROOM_PASSWORD.
# docker-compose.yml and `node dist/index.js` both read these.

# Required — the shared room password; the relay exits 1 if unset.
ROOM_PASSWORD=

# Optional overrides (defaults shown):
# PORT=8080
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
# SFU_URL=ws://localhost:7880
