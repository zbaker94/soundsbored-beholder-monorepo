+    environment:
+      - ROOM_PASSWORD=${ROOM_PASSWORD}
+      - SFU_URL=${SFU_URL:-ws://livekit:7880}
+      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY:-devkey}
+      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET:-secret}
+      - PORT=8080
+    ports:
+      - '8080:8080'
+    depends_on:
+      - livekit
